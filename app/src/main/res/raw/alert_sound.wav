local raw_samples = 44100

-- Create a simple beep sound (1000 Hz, 0.5 seconds)
function generate_sound()
    local samples = {}
    for i = 1, raw_samples / 2 do
        local frequency = 1000
        local t = (i - 1) / 44100
        local sample = math.sin(2 * math.pi * frequency * t) * 30000
        table.insert(samples, sample)
    end
    return samples
end

-- Generate and save
local sound_samples = generate_sound()
