<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black"
    android:padding="16dp">

    <!-- GPS Status -->
    <TextView
        android:id="@+id/gps_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/gps_initializing"
        android:textColor="@color/green"
        android:textSize="14sp"
        android:textAlignment="center"
        android:layout_marginBottom="16dp" />

    <!-- Distance Target Input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/distance_label"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_marginEnd="12dp" />

        <EditText
            android:id="@+id/target_distance_input"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="100"
            android:textColor="@color/bright_yellow"
            android:textSize="16sp"
            android:textAlignment="center"
            android:background="@drawable/rounded_input"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/meters"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- Timer Display -->
    <TextView
        android:id="@+id/timer_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0:00.00"
        android:textColor="@color/bright_yellow"
        android:textSize="80sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_weight="1"
        android:gravity="center" />

    <!-- Distance Display -->
    <TextView
        android:id="@+id/distance_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0.00 m"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textAlignment="center"
        android:layout_marginBottom="32dp" />

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/start_button"
            android:layout_width="120dp"
            android:layout_height="60dp"
            android:text="@string/start_button"
            android:textSize="18sp"
            android:background="@drawable/button_rounded"
            android:textColor="@color/black"
            android:layout_marginEnd="12dp" />

        <Button
            android:id="@+id/stop_button"
            android:layout_width="120dp"
            android:layout_height="60dp"
            android:text="@string/stop_button"
            android:textSize="18sp"
            android:background="@drawable/button_rounded_red"
            android:textColor="@color/white"
            android:layout_marginEnd="12dp"
            android:enabled="false" />

        <Button
            android:id="@+id/reset_button"
            android:layout_width="120dp"
            android:layout_height="60dp"
            android:text="@string/reset_button"
            android:textSize="18sp"
            android:background="@drawable/button_rounded"
            android:textColor="@color/black" />

    </LinearLayout>

    <!-- History & Settings Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/history_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/history_label"
            android:textSize="16sp"
            android:background="@drawable/button_rounded"
            android:textColor="@color/black"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/settings_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/settings_label"
            android:textSize="16sp"
            android:background="@drawable/button_rounded"
            android:textColor="@color/black"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- History Records List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/records_list"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>
